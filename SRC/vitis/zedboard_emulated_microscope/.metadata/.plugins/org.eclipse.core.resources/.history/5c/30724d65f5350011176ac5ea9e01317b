		//toggle mux towards the custom spi interface
		//axiGpOutSet(SPI_SEL_1);
		//axiSpiSelectOutSet(SPI_SELECT_1);
		/*
		gpx2_WriteByte(THRESH_TAP_REG, THRESH_TAP_VAL);
